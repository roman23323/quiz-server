  "info": {
    "title": "Quiz API",
    "description": "API docs for the Quiz server",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "jwt": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 32,
            "pattern": "^[^\\u0000]*$"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "maxLength": 128,
            "pattern": "^[^\\u0000]*$"
          }
        },
        "required": [
          "name",
          "password"
        ],
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[^\\u0000]*$"
          },
          "password": {
            "type": "string",
            "pattern": "^[^\\u0000]*$"
          }
        },
        "required": [
          "name",
          "password"
        ],
        "additionalProperties": false
      },
      "UpdateUserDTO": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "CreateQuizDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 128,
            "pattern": "^[^\u0000]*$",
            "description": " (Must not contain null bytes)"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "pattern": "^[^\u0000]*$",
            "description": " (Must not contain null bytes)"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "private",
              "unlisted"
            ],
            "default": "public",
            "pattern": "^[^\u0000]*$",
            "description": " (Must not contain null bytes)"
          },
          "secondsPerQuestion": {
            "type": "integer",
            "minimum": 5,
            "maximum": 1000
          }
        },
        "required": [
          "title",
          "visibility",
          "secondsPerQuestion"
        ],
        "additionalProperties": false
      },
      "UpdateQuizDto": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "CreateQuestionOptionDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "pattern": "^[^\u0000]*$",
            "description": " (Must not contain null bytes)"
          },
          "isCorrect": {
            "type": "boolean"
          },
          "orderIndex": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          }
        },
        "required": [
          "text",
          "isCorrect",
          "orderIndex"
        ],
        "additionalProperties": false
      },
      "CreateQuestionDto": {
        "type": "object",
        "required": [
          "text",
          "questionType",
          "points",
          "orderIndex"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[^\u0000]*$",
            "description": " (Must not contain null bytes)"
          },
          "text": {
            "type": "string",
            "pattern": "^[^\u0000]*$",
            "description": " (Must not contain null bytes)"
          },
          "questionType": {
            "type": "string",
            "enum": [
              "single_choice",
              "text"
            ],
            "pattern": "^[^\u0000]*$",
            "description": " (Must not contain null bytes)"
          },
          "points": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "orderIndex": {
            "type": "integer",
            "minimum": 0,
            "maximum": 50
          }
        },
        "additionalProperties": false,
        "oneOf": [
          {
            "description": "Вариант для одиночного выбора (single_choice)",
            "properties": {
              "questionType": {
                "enum": [
                  "single_choice"
                ]
              },
              "correctAnswer": {
                "type": "string"
              }
            },
            "required": [
              "questionType",
              "correctAnswer"
            ]
          },
          {
